---
interface Props {
  number: string;
  title: string;
  description: string;
  benefits: string[];
  icon: string;
}

const { number, title, description, benefits, icon } = Astro.props;

// SVG icons mapping
const icons: { [key: string]: string } = {
  clipboard: '<svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="#E8401A" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M16 4h2a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h2"></path><rect x="8" y="2" width="8" height="4" rx="1" ry="1"></rect><line x1="9" y1="11" x2="15" y2="11"></line><line x1="9" y1="15" x2="15" y2="15"></line></svg>',
  building: '<svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="#E8401A" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="12 3 20 7.46 20 21 4 21 4 7.46 12 3"></polyline><line x1="12" y1="12" x2="20" y2="12"></line><line x1="12" y1="16" x2="20" y2="16"></line><line x1="4" y1="12" x2="8" y2="12"></line><line x1="4" y1="16" x2="8" y2="16"></line></svg>',
  checklist: '<svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="#E8401A" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M3 12a9 9 0 0 1 9-9 9.75 9.75 0 0 1 6.74 2.74L21 8"></path><path d="M21 3v5h-5"></path><path d="M21 12a9 9 0 0 1-9 9 9.75 9.75 0 0 1-6.74-2.74L3 16"></path><path d="M3 21v-5h5"></path></svg>',
  alert: '<svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="#E8401A" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3.05h16.94a2 2 0 0 0 1.71-3.05L13.71 3.86a2 2 0 0 0-3.42 0z"></path><line x1="12" y1="9" x2="12" y2="13"></line><line x1="12" y1="17" x2="12.01" y2="17"></line></svg>',
  network: '<svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="#E8401A" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="5" r="3"></circle><line x1="12" y1="22" x2="12" y2="8"></line><path d="M5 12H2a3 3 0 0 0 3 3"></path><path d="M19 12h3a3 3 0 0 1-3 3"></path><line x1="5.64" y1="7.05" x2="3.49" y2="5.11"></line><line x1="18.36" y1="7.05" x2="20.51" y2="5.11"></line><line x1="5.64" y1="16.95" x2="3.49" y2="18.89"></line><line x1="18.36" y1="16.95" x2="20.51" y2="18.89"></line></svg>',
  helmet: '<svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="#E8401A" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2z"></path><path d="M12 6v8m-3-5h6"></path></svg>',
};

const selectedIcon = icons[icon] || icons.clipboard;
---

<div class="service-detail-card">
  <div class="service-detail-card__header">
    <div class="service-detail-card__icon" set:html={selectedIcon}></div>
    <div class="service-detail-card__number">{number}</div>
  </div>
  
  <div class="service-detail-card__body">
    <h3 class="service-detail-card__title">{title}</h3>
    <p class="service-detail-card__description">{description}</p>
    
    <div class="service-detail-card__benefits">
      <p class="service-detail-card__benefits-label">Cette prestation permet de :</p>
      <ul class="service-detail-card__list">
        {benefits.map(benefit => (
          <li><span class="benefit-bullet">â†’</span> {benefit}</li>
        ))}
      </ul>
    </div>
    
    <a href="/contact" class="service-detail-card__link">Ã‰changer sur cette prestation â†’</a>
  </div>
</div>

