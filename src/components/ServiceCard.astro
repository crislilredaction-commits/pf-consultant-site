---
const { title, description, icon = 'clipboard', index = 0 } = Astro.props;
const icons = {
  clipboard: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="40" height="40" fill="none" stroke="#E8401A" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M8 4H16"/><path d="M9 4.5H15C15.2761 4.5 15.5 4.72386 15.5 5V6.5H8.5V5C8.5 4.72386 8.72386 4.5 9 4.5Z"/><path d="M7 6.5H17V20H7V6.5Z"/><path d="M10 11H14"/><path d="M10 15H14"/></svg>`,
  building: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="40" height="40" fill="none" stroke="#E8401A" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M6 21V7H18V21"/><path d="M9 21V14H11V21"/><path d="M13 21V12H15V21"/><path d="M6 7L12 3L18 7"/></svg>`,
  checklist: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="40" height="40" fill="none" stroke="#E8401A" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M4 6H20"/><path d="M4 12H20"/><path d="M4 18H14"/><path d="M9 18L11 20L15 16"/></svg>`,
  alert: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="40" height="40" fill="none" stroke="#E8401A" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M12 4L20 20H4L12 4Z"/><path d="M12 9V13"/><path d="M12 17H12.01"/></svg>`,
  network: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="40" height="40" fill="none" stroke="#E8401A" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="6" cy="8" r="2"/><circle cx="18" cy="8" r="2"/><circle cx="12" cy="16" r="2"/><path d="M6 8L12 14L18 8"/></svg>`,
  helmet: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="40" height="40" fill="none" stroke="#E8401A" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M4 12C4 7.58172 7.58172 4 12 4C16.4183 4 20 7.58172 20 12V17C20 19.2091 18.2091 21 16 21H8C5.79086 21 4 19.2091 4 17V12Z"/><path d="M4 12H20"/><path d="M8 12V10H16V12"/></svg>`
};
const iconSvg = icons[icon] ?? icons.clipboard;
const indexLabel = String(index).padStart(2, '0');
---
<article class="service-card">
  <div class="service-card__index" aria-hidden="true">{indexLabel}</div>
  <div class="service-card__icon" aria-hidden="true" set:html={iconSvg}></div>
  <h3 class="service-card__title">{title}</h3>
  <p class="service-card__text">{description}</p>
</article>
