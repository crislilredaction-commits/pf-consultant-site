---
interface Props {
  number: string;
  title: string;
  description: string;
  benefits: string[];
  icon: string;
}

const { number, title, description, benefits, icon } = Astro.props;

// SVG icons mapping
const icons: { [key: string]: string } = {
  clipboard: '<svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="#E8401A" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M16 4h2a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h2"></path><rect x="8" y="2" width="8" height="4" rx="1" ry="1"></rect><line x1="9" y1="11" x2="15" y2="11"></line><line x1="9" y1="15" x2="15" y2="15"></line></svg>',
  building: '<svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="#E8401A" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="12 3 20 7.46 20 21 4 21 4 7.46 12 3"></polyline><line x1="12" y1="12" x2="20" y2="12"></line><line x1="12" y1="16" x2="20" y2="16"></line><line x1="4" y1="12" x2="8" y2="12"></line><line x1="4" y1="16" x2="8" y2="16"></line></svg>',
  checklist: '<svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="#E8401A" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M3 12a9 9 0 0 1 9-9 9.75 9.75 0 0 1 6.74 2.74L21 8"></path><path d="M21 3v5h-5"></path><path d="M21 12a9 9 0 0 1-9 9 9.75 9.75 0 0 1-6.74-2.74L3 16"></path><path d="M3 21v-5h5"></path></svg>',
  alert: '<svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="#E8401A" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3.05h16.94a2 2 0 0 0 1.71-3.05L13.71 3.86a2 2 0 0 0-3.42 0z"></path><line x1="12" y1="9" x2="12" y2="13"></line><line x1="12" y1="17" x2="12.01" y2="17"></line></svg>',
  network: '<svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="#E8401A" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="5" r="3"></circle><line x1="12" y1="22" x2="12" y2="8"></line><path d="M5 12H2a3 3 0 0 0 3 3"></path><path d="M19 12h3a3 3 0 0 1-3 3"></path><line x1="5.64" y1="7.05" x2="3.49" y2="5.11"></line><line x1="18.36" y1="7.05" x2="20.51" y2="5.11"></line><line x1="5.64" y1="16.95" x2="3.49" y2="18.89"></line><line x1="18.36" y1="16.95" x2="20.51" y2="18.89"></line></svg>',
  helmet: '<svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="#E8401A" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2z"></path><path d="M12 6v8m-3-5h6"></path></svg>',
};

const selectedIcon = icons[icon] || icons.clipboard;
---

<div class="service-detail-card">
  <div class="service-detail-card__header">
    <div class="service-detail-card__icon" set:html={selectedIcon}></div>
    <div class="service-detail-card__number">{number}</div>
  </div>
  
  <div class="service-detail-card__body">
    <h3 class="service-detail-card__title">{title}</h3>
    <p class="service-detail-card__description">{description}</p>
    
    <div class="service-detail-card__benefits">
      <p class="service-detail-card__benefits-label">Cette prestation permet de :</p>
      <ul class="service-detail-card__list">
        {benefits.map(benefit => (
          <li><span class="benefit-bullet">→</span> {benefit}</li>
        ))}
      </ul>
    </div>
    
    <a href="/contact" class="service-detail-card__link">Échanger sur cette prestation →</a>
  </div>
</div>

/* =========================================================
   PF Consultant — Premium visual layer
   Concept: cahier de chantier numérique
   ========================================================= */

:root {
  --color-orange: #E8401A;
  --color-dark: #1A1A18;
  --color-cream: #F4F1EC;
  --color-light: #E8E5DF;
  --color-text: #2E2E2C;
  --color-muted: #6B6864;
  --color-white: #FFFFFF;

  --color-orange-light: rgba(232, 64, 26, 0.08);
  --color-orange-glow: rgba(232, 64, 26, 0.18);
  --color-dark-mid: #242420;
  --color-surface: #FAFAF8;

  --font-display: 'Barlow Condensed', sans-serif;
  --font-body: 'Inter', sans-serif;

  --radius: 6px;
  --radius-card: 10px;
  --radius-pill: 4px;

  --shadow-card: 0 2px 12px rgba(0,0,0,0.06), 0 0 0 1px rgba(0,0,0,0.04);
  --shadow-card-hover: 0 8px 32px rgba(0,0,0,0.10), 0 0 0 1px rgba(232,64,26,0.12);
  --shadow-orange: 0 8px 24px rgba(232, 64, 26, 0.28);
}

/* HERO — cahier de chantier numérique */

.hero {
  background:
    linear-gradient(rgba(255,255,255,0.025) 1px, transparent 1px),
    linear-gradient(90deg, rgba(255,255,255,0.025) 1px, transparent 1px),
    radial-gradient(ellipse 55% 50% at 82% -10%, rgba(232,64,26,0.20) 0%, transparent 65%),
    #1A1A18 !important;
  background-size: 60px 60px, 60px 60px, auto, auto !important;
}

.hero__body {
  padding-top: 5.5rem !important;
  padding-bottom: 4.5rem !important;
}

.hero__eyebrow {
  display: inline-flex !important;
  align-items: center;
  gap: 0.65rem;
  font-size: 0.72rem !important;
  letter-spacing: 0.28em !important;
  text-transform: uppercase;
  color: var(--color-orange) !important;
  font-weight: 700;
}

.hero__eyebrow::before {
  content: '';
  display: inline-block;
  width: 22px;
  height: 1px;
  background: var(--color-orange);
}

.hero__title {
  font-family: var(--font-display) !important;
  font-size: clamp(3.5rem, 7vw, 6.5rem) !important;
  font-weight: 700 !important;
  line-height: 0.94 !important;
  letter-spacing: -0.01em !important;
  color: #F4F1EC !important;
  text-transform: none;
}

.hero__sub {
  font-size: 1.15rem !important;
  font-weight: 500 !important;
  color: rgba(244, 241, 236, 0.76) !important;
  max-width: 640px;
}

.hero__copy {
  font-size: 1rem !important;
  line-height: 1.65 !important;
  color: rgba(244, 241, 236, 0.58) !important;
  max-width: 540px;
}

.hero__copy::before {
  content: '';
  display: block;
  width: 42px;
  height: 2px;
  background: var(--color-orange);
  margin: 1.25rem 0;
}

/* Panneau image hero — repères de calque technique */

.panel-abstract {
  position: relative;
  border-radius: var(--radius-card) !important;
  border: 1px solid rgba(255,255,255,0.08) !important;
  box-shadow: 0 20px 60px rgba(0,0,0,0.32) !important;
  overflow: hidden;
}

.panel-abstract::before,
.panel-abstract::after {
  content: '';
  position: absolute;
  width: 24px;
  height: 24px;
  z-index: 4;
  pointer-events: none;
}

.panel-abstract::before {
  top: 14px;
  left: 14px;
  border-top: 1.5px solid rgba(232,64,26,0.65);
  border-left: 1.5px solid rgba(232,64,26,0.65);
}

.panel-abstract::after {
  right: 14px;
  bottom: 14px;
  border-right: 1.5px solid rgba(232,64,26,0.65);
  border-bottom: 1.5px solid rgba(232,64,26,0.65);
}

/* Boutons — moins SaaS, plus BTP premium */

.button,
.btn,
a.button {
  border-radius: var(--radius-pill) !important;
  text-transform: uppercase;
  letter-spacing: 0.05em;
  font-size: 0.88rem !important;
  font-weight: 700 !important;
}

.button--primary,
.btn--primary {
  background: var(--color-orange) !important;
  color: #FFFFFF !important;
  box-shadow: var(--shadow-orange);
}

.button--secondary,
.btn--secondary {
  background: transparent !important;
  color: rgba(244,241,236,0.86) !important;
  border: 1px solid rgba(244,241,236,0.24) !important;
}

/* Titres de sections */

.section-title {
  font-family: var(--font-display) !important;
  font-size: clamp(2.2rem, 4vw, 3.4rem) !important;
  line-height: 1 !important;
  letter-spacing: 0.01em !important;
}

.section-tag,
.section-label {
  letter-spacing: 0.22em !important;
}

/* Cartes prestations — plus techniques */

.service-card {
  background: var(--color-surface) !important;
  border-radius: var(--radius-card) !important;
  border: 1px solid rgba(30,30,28,0.08) !important;
  box-shadow: var(--shadow-card) !important;
  position: relative;
  overflow: hidden;
}

.service-card::before {
  content: '';
  position: absolute;
  inset: 0 auto auto 0;
  width: 100%;
  height: 2px;
  background: linear-gradient(90deg, var(--color-orange), transparent 72%);
  opacity: 0;
  transition: opacity 0.22s ease;
}

.service-card:hover {
  transform: translateY(-4px);
  box-shadow: var(--shadow-card-hover) !important;
  border-color: rgba(232,64,26,0.16) !important;
}

.service-card:hover::before {
  opacity: 1;
}

.service-card__index {
  font-family: var(--font-display) !important;
  font-size: 2.35rem !important;
  opacity: 1 !important;
  color: rgba(30,30,28,0.07) !important;
}

.service-card__icon {
  width: 48px !important;
  height: 48px !important;
  border-radius: 8px !important;
  background: var(--color-orange-light) !important;
  clip-path: polygon(0 0, calc(100% - 9px) 0, 100% 9px, 100% 100%, 0 100%);
}

.service-card__icon svg {
  width: 26px !important;
  height: 26px !important;
}

.service-card__title {
  font-size: 1.05rem !important;
  line-height: 1.25 !important;
}

.service-card__text {
  font-size: 0.92rem !important;
  line-height: 1.6 !important;
}

/* Pourquoi choisir — plus premium */

.section--why {
  background:
    linear-gradient(rgba(255,255,255,0.018) 1px, transparent 1px),
    linear-gradient(90deg, rgba(255,255,255,0.018) 1px, transparent 1px),
    radial-gradient(circle at 85% 10%, rgba(232,64,26,0.10), transparent 34%),
    linear-gradient(180deg, #1A1A18 0%, #111110 100%) !important;
  background-size: 80px 80px, 80px 80px, auto, auto !important;
}

.feature-card {
  position: relative;
  border-radius: var(--radius-card) !important;
  background: rgba(255,255,255,0.035) !important;
  border: 1px solid rgba(255,255,255,0.075) !important;
  padding-left: 3rem !important;
}

.feature-card::before {
  content: '';
  position: absolute;
  left: 1.5rem;
  top: 1.65rem;
  bottom: 1.65rem;
  width: 2px;
  background: linear-gradient(180deg, var(--color-orange), rgba(232,64,26,0.14));
  border-radius: 999px;
}

.feature-card__title,
.feature-card h3 {
  font-family: var(--font-display) !important;
  font-size: 1.35rem !important;
}

/* CTA final — section de conversion orange */

.contact-cta {
  background:
    linear-gradient(rgba(255,255,255,0.06) 1px, transparent 1px),
    linear-gradient(90deg, rgba(255,255,255,0.06) 1px, transparent 1px),
    var(--color-orange) !important;
  background-size: 60px 60px, 60px 60px, auto !important;
  color: white !important;
  border-radius: 0 !important;
}

.contact-cta__title,
.contact-cta h2 {
  font-family: var(--font-display) !important;
  color: white !important;
  font-size: clamp(2rem, 4vw, 3.2rem) !important;
}

.contact-cta__text,
.contact-cta p {
  color: rgba(255,255,255,0.78) !important;
}

.contact-cta .button--primary,
.contact-cta .btn--primary {
  background: #FFFFFF !important;
  color: var(--color-orange) !important;
  box-shadow: 0 8px 24px rgba(0,0,0,0.18) !important;
}

.contact-cta .button--secondary,
.contact-cta .btn--secondary {
  background: transparent !important;
  color: #FFFFFF !important;
  border: 1px solid rgba(255,255,255,0.42) !important;
}

/* Responsive */

@media (max-width: 900px) {
  .hero__body {
    padding-top: 4rem !important;
    padding-bottom: 3.5rem !important;
  }
}

@media (max-width: 640px) {
  .hero__title {
    font-size: clamp(3rem, 18vw, 4.5rem) !important;
  }

  .hero__body {
    padding-top: 3rem !important;
    padding-bottom: 3rem !important;
  }
}
