---
import BaseLayout from '../layouts/BaseLayout.astro';
import ImagePlaceholder from '../components/ImagePlaceholder.astro';
---
<BaseLayout title="Contact | PF Consultant" description="Contactez PF Consultant pour une assistance de chantier, un suivi de projet ou une réception de travaux.">
  <section class="section">
    <div class="container">
      <div class="contact-grid">
        <div>
          <h1 class="section-title">Contact</h1>
          <p class="section-subtitle">Pour échanger sur votre projet, utilisez le formulaire ou contactez directement PF Consultant.</p>
        </div>
        <ImagePlaceholder label="Image à ajouter" variant="secondary" />
      </div>
      <form class="contact-cta" action="https://formspree.io/f/REMPLACER_PAR_ENDPOINT" method="POST">
        <!-- Remplacez l'endpoint Formspree ci-dessus par votre endpoint personnel après création du formulaire. -->
        <div class="form-grid">
          <div class="field">
            <label for="name">Nom</label>
            <input id="name" name="name" type="text" required />
          </div>
          <div class="field">
            <label for="phone">Téléphone</label>
            <input id="phone" name="phone" type="tel" required />
          </div>
          <div class="field">
            <label for="email">Email</label>
            <input id="email" name="email" type="email" required />
          </div>
          <div class="field">
            <label for="subject">Objet</label>
            <input id="subject" name="subject" type="text" required />
          </div>
        </div>
        <div class="field">
          <label for="message">Message</label>
          <textarea id="message" name="message" required></textarea>
        </div>
        <div style="display:none;">
          <label>Ne pas remplir</label>
          <input type="text" name="website" tabindex="-1" autocomplete="off" />
        </div>
        <button class="button button--primary" type="submit">Envoyer le message</button>
      </form>
    </div>
  </section>
</BaseLayout>
