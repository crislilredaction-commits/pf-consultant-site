---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Politique de confidentialité | PF Consultant" description="Politique de confidentialité de PF Consultant pour la gestion des données personnelles.">
  <section class="section">
    <div class="container">
      <h1 class="section-title">Politique de confidentialité</h1>
      <p class="section-subtitle">Cette page présente les principes de collecte et de traitement des données personnelles.</p>
      <div style="margin-top:2rem; display:grid; gap:1rem;">
        <p>Les informations collectées via le formulaire de contact sont utilisées uniquement pour répondre à votre demande.</p>
        <p>Aucun autre traitement ni partage de données n'est effectué sans votre consentement explicite.</p>
      </div>
    </div>
  </section>
</BaseLayout>
